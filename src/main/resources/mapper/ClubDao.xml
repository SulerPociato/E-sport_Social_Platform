<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.soecode.lyf.dao.ClubDao" >

    <resultMap id="BaseResultMap" type="com.soecode.lyf.entity.Club" >
        <id column="club_id" property="clubId" jdbcType="BIGINT" />
        <result column="club_name" property="clubName" jdbcType="VARCHAR" />
        <result column="description" property="description" jdbcType="VARCHAR" />
        <result column="admin_id" property="adminId" jdbcType="BIGINT" />
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP" />
    </resultMap>

    <select id="queryAll" resultMap="BaseResultMap">
        SELECT
            club_id,
            club_name,
            description,
            admin_id,
            create_time
        FROM Club
        ORDER BY club_id DESC
    </select>

    <select id="queryById" parameterType="long" resultMap="BaseResultMap">
        SELECT
            club_id,
            club_name,
            description,
            admin_id,
            create_time
        FROM Club
        WHERE club_id = #{clubId}
    </select>

    <select id="queryById" parameterType="long" resultMap="ClubResultMap">
        SELECT
            club_id,
            club_name,
            description,
            admin_id,
            create_time
        FROM Club
        WHERE club_id = #{clubId}
    </select>

    <insert id="insert" parameterType="Club">
        INSERT INTO Club (
            club_name,
            description,
            admin_id,
            create_time
        ) VALUES (
            #{clubName},
            #{description},
            #{adminId},
            NOW()
        )
    </insert>

    <update id="update" parameterType="Club">
        UPDATE Club
        SET
            club_name = #{clubName},
            description = #{description},
            admin_id = #{adminId},
            update_time = NOW()
        WHERE club_id = #{clubId}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM Club WHERE club_id = #{clubId}
    </delete>

</mapper>