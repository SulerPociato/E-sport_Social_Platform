<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.soecode.lyf.dao.ClubDao">

    <resultMap id="BaseResultMap" type="com.soecode.lyf.entity.Club">
        <id column="id" property="clubId" jdbcType="BIGINT"/>
        <result column="club_name" property="clubName" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="admin_id" property="adminId" jdbcType="BIGINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="avatar" property="avatar" jdbcType="VARCHAR"/>
    </resultMap>

    <select id="queryAll" resultMap="BaseResultMap">
        select
            id,
            club_name,
            description,
            admin_id,
            create_time,
            avatar
        from club
        order by id desc
    </select>

    <select id="queryById" parameterType="long" resultMap="BaseResultMap">
        select
            id,
            club_name,
            description,
            admin_id,
            create_time,
            avatar
        from club
        where id = #{clubId}
    </select>

    <insert id="insert" parameterType="com.soecode.lyf.entity.Club" useGeneratedKeys="true" keyProperty="clubId">
        insert into club (
            club_name,
            description,
            admin_id,
            avatar
        ) values (
                     #{clubName},
                     #{description},
                     #{adminId},
                     #{avatar}
                 )
    </insert>

    <update id="update" parameterType="com.soecode.lyf.entity.Club">
        update club
        set
            club_name = #{clubName},
            description = #{description},
            admin_id = #{adminId},
            avatar = #{avatar}
        where id = #{clubId}
    </update>

    <delete id="delete" parameterType="long">
        delete from club where id = #{clubId}
    </delete>

</mapper>